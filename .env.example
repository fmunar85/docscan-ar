# ══════════════════════════════════════════════════════
#  DocScan AR — Variables de entorno
#  Copiá este archivo a .env y completá los valores
# ══════════════════════════════════════════════════════

# ─── Flask ─────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-aleatoria
FLASK_DEBUG=false

# ─── OCR (al menos uno requerido) ──────────────────────
#
# OPCIÓN A: OpenAI GPT-4o  (recomendado — mejor precisión)
OPENAI_API_KEY=sk-...

# OPCIÓN B: Google Cloud Vision API
# Pegá el JSON completo de tu Service Account entre comillas simples:
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# ─── Google Sheets ──────────────────────────────────────
#
# ID del spreadsheet (lo encontrás en la URL de Google Sheets)
# https://docs.google.com/spreadsheets/d/  <<< ESTE ES EL ID >>>  /edit
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Credenciales de Service Account (mismas que Vision si usás Google)
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account",...}'
